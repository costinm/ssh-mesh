[
  {
    "name": "esp.serial.command",
    "title": "ESP Serial Command",
    "group": "ESP32 Debug",
    "description": "Low-level debug action: run one firmware command over a serial, BLE, or raw-Wi-Fi firmware adapter and return parsed text records. lmesh may use this internally, but product flows should prefer higher-level radio tools.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "adapter": {
          "type": [
            "string",
            "null"
          ],
          "title": "Adapter",
          "description": "lmesh radio adapter id. If omitted, lmesh may choose the default ESP adapter."
        },
        "port": {
          "type": [
            "string",
            "null"
          ],
          "title": "Serial port",
          "description": "Optional direct serial device path such as /dev/ttyUSB4."
        },
        "command": {
          "type": "string",
          "title": "Command"
        },
        "timeout_sec": {
          "type": "number",
          "title": "Timeout seconds",
          "default": 5
        }
      },
      "required": [
        "command"
      ],
      "additionalProperties": false
    },
    "x-stability": "debug",
    "x-layer": "low-level",
    "x-source": "fw/esp32/rust",
    "x-mcp-scope": "lmesh-adapter-debug"
  },
  {
    "name": "esp.flash.classic",
    "title": "Flash Classic ESP32",
    "group": "ESP32 Debug",
    "description": "Low-level test action: build and flash the Rust firmware to a classic ESP32 board using the 4 MB partition profile.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "port": {
          "type": "string",
          "title": "Serial port"
        },
        "release": {
          "type": "boolean",
          "title": "Release build",
          "default": true
        }
      },
      "required": [
        "port"
      ],
      "additionalProperties": false
    },
    "x-stability": "debug",
    "x-layer": "low-level",
    "x-source": "fw/esp32/rust",
    "x-mcp-scope": "firmware-test-only"
  },
