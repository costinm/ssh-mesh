  {
    "name": "esp.lora.cad_test",
    "title": "LoRa CAD Regression",
    "group": "ESP32 Debug",
    "description": "Low-level two-board regression used during firmware development to prove LoRa CAD receive behavior, including SX127x 16-symbol preamble receive.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "rx_adapter": {
          "type": [
            "string",
            "null"
          ],
          "title": "Receiver adapter"
        },
        "tx_adapter": {
          "type": [
            "string",
            "null"
          ],
          "title": "Sender adapter"
        },
        "rx_port": {
          "type": [
            "string",
            "null"
          ],
          "title": "Receiver serial port"
        },
        "tx_port": {
          "type": [
            "string",
            "null"
          ],
          "title": "Sender serial port"
        },
        "packets": {
          "type": "integer",
          "title": "Packets",
          "default": 8,
          "minimum": 1
        },
        "preamble": {
          "type": "integer",
          "title": "LoRa preamble symbols",
          "default": 16,
          "minimum": 6
        },
        "cad_interval_ms": {
          "type": "integer",
          "title": "Configured CAD interval",
          "default": 2000,
          "minimum": 5
        },
        "cad_rx_ms": {
          "type": "integer",
          "title": "CAD-triggered RX window",
          "default": 1000,
          "minimum": 50
        },
        "expect_all": {
          "type": "boolean",
          "title": "Require all packets",
          "default": true
        }
      },
      "additionalProperties": false
    },
    "x-stability": "debug",
    "x-layer": "low-level",
    "x-source": "fw/esp32/rust",
    "x-mcp-scope": "firmware-test-only"
  },
