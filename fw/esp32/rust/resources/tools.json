  {
    "name": "esp.power.profile",
    "title": "ESP Power Profile",
    "group": "Radio Status",
    "description": "Configure or report the firmware power profile. Default is dfs: dynamic frequency scaling enabled with automatic light sleep disabled.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "adapter": {
          "type": [
            "string",
            "null"
          ],
          "title": "Adapter"
        },
        "port": {
          "type": [
            "string",
            "null"
          ],
          "title": "Serial port"
        },
        "profile": {
          "type": [
            "string",
            "null"
          ],
          "title": "Profile",
          "enum": [
            "dfs",
            "perf",
            "low",
            "auto",
            null
          ]
        },
        "save": {
          "type": "boolean",
          "title": "Persist in NVS",
          "default": false
        }
      },
      "additionalProperties": false
    },
    "x-stability": "stable",
    "x-layer": "high-level",
    "x-source": "fw/esp32/rust",
    "x-mcp-scope": "lmesh-adapter-debug"
  },
