# mesh-init service definition for app5-vm's ssh-mesh node.

[Service]
MeshUID = 103
MeshGID = 103

ExecStart = "ssh-mesh"
OOMScoreAdjust = -900
[[Peer]]
uid = 103

[Resources]
memory_high = "256M"
memory_max = "512M"
cpu_weight = 100

[Environment]
PATH = "/opt/ssh-mesh/bin:/opt/initos/bin:/opt/busybox/bin"
RUST_LOG = "info"
SSH_PORT = "18522"
HTTP_PORT = "18580"
MUX_DIR = "/home/app5/run/ssh-mesh/mux"
MESH_INIT_SOCK = "/home/app5/run/mesh-init/control.sock"
SSH_MESH_HOME_ROOT = "/home"
