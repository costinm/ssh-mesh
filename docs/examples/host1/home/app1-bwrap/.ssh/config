# Example OpenSSH client entries installed at $HOME/.ssh/config for app-bwrap.
#
# These are for human testing from inside the app-bwrap sandbox.

Host host3-vm-tcp
  HostName 127.0.0.1
  Port 18322
  User app-bwrap

Host host3-vm-http
  HostName host3-vm-over-http
  User app-bwrap
  ProxyCommand h2t http://127.0.0.1:18380/_m/_ssh

Host host1-tcp
  HostName 127.0.0.1
  Port 18422
  User app-bwrap

Host host1-http
  HostName host1-over-http
  User app-bwrap
  ProxyCommand h2t http://127.0.0.1:18480/_m/_ssh

