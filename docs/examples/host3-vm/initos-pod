#!/opt/busybox/bin/sh
set -eu

action="${1:-start}"

if [ "${action}" != "start" ]; then
  echo "host3-vm initos-pod only supports: start" >&2
  exit 2
fi

export PATH=/opt/ssh-mesh/bin:/opt/initos/bin:/opt/busybox/bin

if [ -e /src/host3-vm/nix-profile ]; then
  export NIX_PROFILE=/src/host3-vm/nix-profile
  export PATH="${PATH}:${NIX_PROFILE}/bin"
fi

log() {
  echo "HOST3_VM-POD: $*"
}

setup_kvm_device() {
  if ! grep -Eq '(^flags|^Features).* (vmx|svm)( |$)' /proc/cpuinfo 2>/dev/null; then
    log "nested KVM unavailable: guest CPU has no vmx/svm flag"
  fi

  modprobe kvm 2>/dev/null || true
  modprobe kvm_intel 2>/dev/null || modprobe kvm_amd 2>/dev/null || true
  mdev -s 2>/dev/null || true

  if [ ! -e /dev/kvm ] && [ -r /proc/misc ]; then
    kvm_minor="$(awk '$2 == "kvm" { print $1; exit }' /proc/misc)"
    if [ -n "${kvm_minor}" ]; then
      mknod -m 660 /dev/kvm c 10 "${kvm_minor}" 2>/dev/null || true
      chown 0:0 /dev/kvm 2>/dev/null || true
    fi
  fi

  if [ -e /dev/kvm ]; then
    log "nested KVM device present: $(ls -l /dev/kvm)"
  else
    log "nested KVM device missing; /proc/misc entry: $(grep -E ' kvm$' /proc/misc 2>/dev/null || true)"
  fi
}

mount_mesh9p_tcp() {
  name="$1"
  port="$2"
  mountpoint="/tmp/mesh/9p/${name}"
  gateway="${SSH_MESH_9P_HOST_GATEWAY:-10.0.2.2}"

  modprobe 9pnet 2>/dev/null || true
  modprobe 9pnet_tcp 2>/dev/null || true
  modprobe 9p 2>/dev/null || true

  mkdir -p "${mountpoint}"
  n=0
  while [ "${n}" -lt 60 ]; do
    if mount -t 9p -o "trans=tcp,version=9p2000.L,port=${port},uname=system,access=any" "${gateway}" "${mountpoint}" 2>/dev/null; then
      log "mounted ${name} 9p export from ${gateway}:${port} at ${mountpoint}"
      return 0
    fi
    n=$((n + 1))
    sleep 1
  done

  log "warning: failed to mount ${name} 9p export from ${gateway}:${port}"
  return 1
}

home_src=/src/host3-vm/home/system
home=/home/system
root_home=/home/root
sshd_uid=103
sshd_gid=103

mkdir -p \
  "${home}" \
  "${root_home}" \
  "${root_home}/.ssh" \
  "${home}/etc/mesh-init" \
  "${home}/etc/ssh-mesh" \
  "${home}/run/mesh-init" \
  "${home}/run/ssh-mesh/mux" \
  "${home}/.ssh" \
  /tmp/mesh \
  /tmp/mesh/shared \
  /tmp/mesh/9p

if [ -d /src/shared ]; then
  if mount -o bind /src/shared /tmp/mesh/shared 2>/dev/null; then
    log "bound /src/shared to /tmp/mesh/shared"
  else
    log "bind mount /src/shared failed; trusted UDS sharing may be unavailable"
  fi
fi

if [ -d /src/nix ]; then
  mkdir -p /nix
  if mount -o bind,ro /src/nix /nix 2>/dev/null; then
    log "mounted /src/nix to /nix read-only"
  else
    log "warning: failed to mount /src/nix to /nix"
  fi
fi
if [ ! -e /nix/store ]; then
  mkdir -p /nix
  nix_9p=0
  for tag9p in /sys/bus/virtio/drivers/9pnet_virtio/virtio*/mount_tag; do
    [ -f "${tag9p}" ] || continue
    if [ "$(cat "${tag9p}" 2>/dev/null || true)" = "nix" ]; then
      nix_9p=1
      break
    fi
  done
  if [ "${nix_9p}" = "1" ] && mount -t 9p -o trans=virtio,version=9p2000.L,ro nix /nix 2>/dev/null; then
    log "mounted 9p tag nix to /nix read-only"
  else
    log "nix share not present; skipping /nix mount"
  fi
fi

if [ -d "${home_src}" ]; then
  if mount -o bind "${home_src}" "${home}" 2>/dev/null; then
    log "bound ${home_src} to ${home}"
  else
    log "bind mount failed; using ${home_src} directly"
    home="${home_src}"
  fi
fi

# Mount a tmpfs on ${home}/run to avoid placing UDS sockets on 9p share which QEMU blocks
mkdir -p "${home}/run"
if mount -t tmpfs -o mode=0777,nosuid,nodev tmpfs "${home}/run" 2>/dev/null; then
  log "mounted tmpfs on ${home}/run"
else
  log "warning: failed to mount tmpfs on ${home}/run"
fi

mkdir -p \
  "${home}/etc/mesh-init" \
  "${home}/etc/ssh-mesh" \
  "${home}/run/mesh-init" \
  "${home}/run/ssh-mesh/mux" \
  "${home}/.ssh" \
  "${root_home}" \
  "${root_home}/.ssh"

chmod 700 "${home}/.ssh"
chmod 700 "${root_home}" "${root_home}/.ssh"
chown 0:0 "${root_home}" "${root_home}/.ssh" 2>/dev/null || true
chmod 600 "${home}/.ssh/config" 2>/dev/null || true
chown -R "${sshd_uid}:${sshd_gid}" \
  "${home}/.ssh" \
  "${home}/etc/ssh-mesh" \
  "${home}/run/ssh-mesh" 2>/dev/null || true

ip link set lo up 2>/dev/null || true
ip link set eth0 up 2>/dev/null || true
udhcpc -i eth0 -q -n -t 5 2>/dev/null || log "dhcp on eth0 failed"
setup_kvm_device

mount_mesh9p_tcp host1 15101 || true
mount_mesh9p_tcp host2 15102 || true

export HOME="${home}"
export USER=system
export LOGNAME=system
export RUST_LOG="${RUST_LOG:-info}"
export MESH_LOG_FILE="${MESH_LOG_FILE:-/dev/console}"
export MESH_INIT_SOCK="${home}/run/mesh-init/control.sock"
export MESH_INIT_RUN="${home}/run/mesh-init"
export MESH_INIT_DIR="${home}/etc/mesh-init"
export SSH_MESH_HOME_ROOT=/home

log "starting mesh-init from /opt/ssh-mesh/bin/mesh-init"
exec /opt/ssh-mesh/bin/mesh-init
