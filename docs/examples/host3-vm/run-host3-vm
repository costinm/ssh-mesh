#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
workspace_dir="$(cd "${script_dir}/../../.." 2>/dev/null && pwd)"
target_dir="${SSH_MESH_TARGET_DIR:-${workspace_dir}/target}"
artifact_dir="${target_dir}/dist"
default_nix_profile="${target_dir}/nix/profile"
nix_profile="${NIX_PROFILE:-${default_nix_profile}}"

root_dir="${1:-${target_dir}/examples}"
if [ "$#" -gt 0 ]; then
  shift
fi

export NIX_PROFILE="${nix_profile}"
if [ -d "${NIX_PROFILE}/bin" ]; then
  export PATH="${NIX_PROFILE}/bin:${PATH}"
fi
export PATH="${artifact_dir}/opt/ssh-mesh/bin:${artifact_dir}/opt/busybox/bin:${PATH}"

rootfs="${artifact_dir}/img/ssh-mesh.erofs"
vrun="${artifact_dir}/opt/ssh-mesh/bin/vrun"

if [ ! -x "${vrun}" ] ||
   ! VIRT="${NIX_PROFILE}" VIRT_ROOTFS="${rootfs}" "${vrun}" available qemuvirt >/dev/null 2>&1; then
    cat >&2 <<EOF
Host3-vm requires vrun, a readable rootfs, a detected VM kernel profile, and qemu.

Build them with:
  ${workspace_dir}/scripts/build.sh profile
  ${workspace_dir}/scripts/build.sh

Or set VIRT/VIRT_KERNEL/VIRT_ROOTFS for another kernel/rootfs profile.
EOF
    exit 2
fi

export POD=host3-vm
export SSH_MESH_VM_NODE=host3-vm
export SSH_MESH_VRUN_HOST=1
export SSH_MESH_STATE_ROOT="${root_dir}"
export VRUN_TEMPLATE_DIR="${script_dir}"
export VRUN_DIST_DIR="${artifact_dir}"
export SSH_MESH_VM_HYPERVISOR="${SSH_MESH_VM_HYPERVISOR:-qemu}"
export SSH_MESH_VM_HOST_SSH_PORT="${SSH_MESH_HOST3_VM_HOST_SSH_PORT:-${SSH_MESH_VM_HOST_SSH_PORT:-18322}}"
export SSH_MESH_VM_HOST_HTTP_PORT="${SSH_MESH_HOST3_VM_HOST_HTTP_PORT:-${SSH_MESH_VM_HOST_HTTP_PORT:-18380}}"
export SSH_MESH_VM_GUEST_IP="${SSH_MESH_HOST3_VM_GUEST_IP:-${SSH_MESH_VM_GUEST_IP:-10.0.2.15/24}}"
export SSH_MESH_VM_GUEST_GW="${SSH_MESH_HOST3_VM_GUEST_GW:-${SSH_MESH_VM_GUEST_GW:-10.0.2.2}}"
export SSH_MESH_VM_MEMORY="${SSH_MESH_HOST3_VM_QEMU_MEMORY:-${SSH_MESH_VM_MEMORY:-1024M}}"
export SSH_MESH_VM_CPUS="${SSH_MESH_HOST3_VM_QEMU_CPUS:-${SSH_MESH_VM_CPUS:-2}}"

exec "${vrun}" start "$@"
