#!/usr/bin/env bash
set -euo pipefail
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
examples_dir="$(cd "${script_dir}/../../.." 2>/dev/null && pwd)"
workspace_dir="$(cd "${examples_dir}/../.." 2>/dev/null && pwd)"
target_dir="${SSH_MESH_TARGET_DIR:-${workspace_dir}/target}"
default_nix_profile="${target_dir}/nix/profile"
if [ ! -e "${default_nix_profile}" ] && [ -e "${target_dir}/nix/profiles" ]; then
  default_nix_profile="${target_dir}/nix/profiles"
fi
nix_profile="${NIX_PROFILE:-${default_nix_profile}}"
export NIX_PROFILE="${nix_profile}"
if [ -d "${NIX_PROFILE}/bin" ]; then
  export PATH="${NIX_PROFILE}/bin:${PATH}"
fi
mode="${1:---vsock}"
case "${mode}" in
  vsock|--vsock) mode="vsock" ;;
  *)
    echo "usage: $0 [--vsock]" >&2
    exit 2
    ;;
esac
shift
# Try to locate the VM assets
if [ -n "${SSH_MESH_APP_VM_DIR:-}" ]; then
  vm_dir="${SSH_MESH_APP_VM_DIR}"
elif [ -n "${SSH_MESH_HOST3_VM_DIR:-}" ]; then
  vm_dir="${SSH_MESH_HOST3_VM_DIR}"
elif [ -d "${workspace_dir}/result-default" ]; then
  vm_dir="${workspace_dir}/result-default"
elif [ -d "${examples_dir}/share/host3-vm-vm" ]; then
  vm_dir="${examples_dir}/share/host3-vm-vm"
elif [ -d "${nix_profile}/opt/ssh-mesh/share/host3-vm-vm" ]; then
  vm_dir="${nix_profile}/opt/ssh-mesh/share/host3-vm-vm"
else
  vm_dir="/opt/ssh-mesh/share/host3-vm-vm"
fi
# Locate kernel
if [ -f "${vm_dir}/img/vmlinux-cloud" ]; then
  kernel="${vm_dir}/img/vmlinux-cloud"
elif [ -f "${nix_profile}/img/vmlinux-cloud" ]; then
  kernel="${nix_profile}/img/vmlinux-cloud"
elif [ -f "${vm_dir}/bzImage" ]; then
  kernel="${vm_dir}/bzImage"
else
  kernel="${SSH_MESH_APP_VM_KERNEL:-${SSH_MESH_HOST3_VM_KERNEL:-${vm_dir}/bzImage}}"
fi
# Locate rootfs
if [ -f "${vm_dir}/img/ssh-mesh.erofs" ]; then
  rootfs="${vm_dir}/img/ssh-mesh.erofs"
elif [ -f "${vm_dir}/initos.erofs" ]; then
  rootfs="${vm_dir}/initos.erofs"
else
  rootfs="${SSH_MESH_APP_VM_ROOTFS:-${SSH_MESH_HOST3_VM_ROOTFS:-${vm_dir}/initos.erofs}}"
fi
node="${SSH_MESH_VM_NODE:-app2-qemu}"
case "${node}" in
  app2-qemu) app_home="${SSH_MESH_APP_HOME:-app2}" ;;
  app3-crosvm) app_home="${SSH_MESH_APP_HOME:-app3}" ;;
  app4-ch) app_home="${SSH_MESH_APP_HOME:-app4}" ;;
  *) app_home="${SSH_MESH_APP_HOME:-${node}}" ;;
esac
root_dir="${SSH_MESH_EXAMPLE_ROOT:-${target_dir}/examples}"
export SSH_MESH_EXAMPLE_ROOT="${root_dir}"
state_dir="${root_dir}/${node}"
state_home_dir="${state_dir}/home/${app_home}"
shared_dir="${root_dir}/shared"
work_dir="${state_dir}/vm"
share_dir="${work_dir}/share"
src_dir="${state_dir}/src"
need() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "missing required command: $1" >&2
    exit 1
  }
}
vrun_bin="${SSH_MESH_VRUN:-}"
if [ -z "${vrun_bin}" ] && [ -x /out/ssh-mesh/bin/vrun ]; then
  vrun_bin="/out/ssh-mesh/bin/vrun"
elif [ -z "${vrun_bin}" ] && [ -x /opt/ssh-mesh/bin/vrun ]; then
  vrun_bin="/opt/ssh-mesh/bin/vrun"
elif [ -z "${vrun_bin}" ] && [ -n "${SSH_MESH_EXAMPLE_BIN_DIR:-}" ] && [ -x "${SSH_MESH_EXAMPLE_BIN_DIR}/vrun" ]; then
  vrun_bin="${SSH_MESH_EXAMPLE_BIN_DIR}/vrun"
elif [ -z "${vrun_bin}" ] && [ -x "${workspace_dir}/linux/bin/vrun" ]; then
  vrun_bin="${workspace_dir}/linux/bin/vrun"
elif [ -z "${vrun_bin}" ]; then
  need vrun
  vrun_bin="vrun"
fi
for f in "${kernel}" "${rootfs}"; do
  if [ ! -r "${f}" ]; then
    cat >&2 <<EOF
App VM requires readable VM artifacts.
Missing: ${f}
Set SSH_MESH_APP_VM_DIR, or set SSH_MESH_APP_VM_KERNEL and SSH_MESH_APP_VM_ROOTFS.
EOF
    exit 2
  fi
done
mkdir -p \
  "${state_home_dir}/.config/mesh-init" \
  "${state_home_dir}/.config/ssh-mesh" \
  "${state_home_dir}/.run/mesh-init" \
  "${state_home_dir}/.run/ssh-mesh/mux" \
  "${state_home_dir}/.ssh" \
  "${shared_dir}" \
  "${share_dir}/bin" \
  "${share_dir}/${node}/home" \
  "${src_dir}" \
  "${work_dir}"
launch_log="${work_dir}/launch.log"
if [ ! -t 1 ]; then
  exec </dev/null >>"${launch_log}" 2>&1
fi
rm -rf "${share_dir}/${node}/home/${app_home}" "${share_dir}/initos" "${src_dir}"
mkdir -p "${share_dir}/bin" "${share_dir}/${node}/home" "${share_dir}/initos" "${src_dir}"

if [ -d /nix ]; then
  rm -rf "${share_dir}/nix"
  mkdir -p "${share_dir}/nix"
  if mount --bind /nix "${share_dir}/nix" 2>/dev/null; then
    mount -o remount,ro,bind "${share_dir}/nix" 2>/dev/null || true
  else
    rmdir "${share_dir}/nix" 2>/dev/null || true
  fi
fi
if [ -e "${nix_profile}" ]; then
  ln -sfn "${nix_profile}" "${state_home_dir}/nix-profile"
fi
# Locate the guest initos-pod
if [ -f "${script_dir}/initos-pod" ]; then
  initos_pod_src="${script_dir}/initos-pod"
elif [ -f "${vm_dir}/initos-pod" ]; then
  initos_pod_src="${vm_dir}/initos-pod"
else
  echo "Error: initos-pod not found" >&2
  exit 1
fi
cp -a "${state_home_dir}" "${share_dir}/${node}/home/${app_home}"
cp "${initos_pod_src}" "${share_dir}/initos/initos-pod"
if [ -d "${vm_dir}/bin" ]; then
  cp "${vm_dir}/bin/"* "${share_dir}/bin/"
elif [ -d "${workspace_dir}/result-ssh-mesh-full/bin" ]; then
  cp "${workspace_dir}/result-ssh-mesh-full/bin/"* "${share_dir}/bin/"
fi
echo "${node} kernel: ${kernel}"
echo "${node} rootfs: ${rootfs}"
echo "${node} src share: ${share_dir}"
echo "${node} node: ${node}"
echo "${node} HOME inside guest: /home/${app_home}"
echo "${node} persistent HOME source: /src/${node}/home/${app_home}"
vm_mem="${SSH_MESH_APP_VM_QEMU_MEMORY:-${SSH_MESH_VM_MEMORY:-512M}}"
vm_mem_mb="${vm_mem}"
case "${vm_mem}" in
  *[!0-9]*) ;;
  *) vm_mem="${vm_mem}M" ;;
esac
case "${vm_mem_mb}" in
  *M) vm_mem_mb="${vm_mem_mb%M}" ;;
  *[!0-9]*) vm_mem_mb="1024" ;;
esac
vm_cpu="${SSH_MESH_APP_VM_QEMU_CPUS:-${SSH_MESH_VM_CPUS:-2}}"
virt="${SSH_MESH_VM_HYPERVISOR:-${virt:-qemu}}"
export POD="${node}"
export WORK="${work_dir}"
export SRC="${src_dir}"
export VIRT="${nix_profile}"
export VIRT_KERNEL="${kernel}"
export VIRT_ROOTFS="${rootfs}"
export NO_NET=1
export vm_mem
export vm_mem_mb
export vm_cpu
export virt
if [ "${mode}" = "vsock" ]; then
  export VSOCK_CID="${SSH_MESH_VM_VSOCK_CID:-${SSH_MESH_APP_VM_VSOCK_CID:-43}}"
  export SSH_MESH_VSOCK_PORT="${SSH_MESH_VM_VSOCK_PORT:-${SSH_MESH_APP_VM_VSOCK_PORT:-18522}}"
fi
exec "${vrun_bin}" start "$@"
