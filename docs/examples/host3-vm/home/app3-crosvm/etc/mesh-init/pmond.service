# Process monitor for app3-crosvm.

[Service]
# Socket activation is declared in pmond.socket.

ExecStart = "pmond"
OOMScoreAdjust = -820
[Resources]
memory_high = "128M"
memory_max = "256M"
cpu_weight = 50

[Environment]
PATH = "/opt/ssh-mesh/bin:/opt/initos/bin:/opt/busybox/bin"
RUST_LOG = "info"
