# Example OpenSSH client entries installed at $HOME/.ssh/config for app-vm-crosvm.

Host host2-tcp
  HostName 127.0.0.1
  Port 18222
  User app-vm-crosvm

Host host2-http
  HostName host2-over-http
  User app-vm-crosvm
  ProxyCommand h2t http://127.0.0.1:18280/_m/_ssh

Host host1-tcp
  HostName 127.0.0.1
  Port 18422
  User app-vm-crosvm

Host host1-http
  HostName host1-over-http
  User app-vm-crosvm
  ProxyCommand h2t http://127.0.0.1:18480/_m/_ssh
