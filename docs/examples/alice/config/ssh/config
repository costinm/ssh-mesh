# Example OpenSSH client entries installed at $HOME/.ssh/config for alice.
#
# These are for human testing from inside the alice sandbox.

Host bob-tcp
  HostName 127.0.0.1
  Port 18322
  User alice

Host bob-http
  HostName bob-over-http
  User alice
  ProxyCommand h2t http://127.0.0.1:18380/_m/_ssh

Host user-tcp
  HostName 127.0.0.1
  Port 18422
  User alice

Host user-http
  HostName user-over-http
  User alice
  ProxyCommand h2t http://127.0.0.1:18480/_m/_ssh

