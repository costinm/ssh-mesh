# Example OpenSSH client entries installed at $HOME/.ssh/config for user.

Host bwrap-net-tcp
  HostName 127.0.0.1
  Port 18222
  User user

Host bwrap-net-http
  HostName bwrap-net-over-http
  User user
  ProxyCommand h2t http://127.0.0.1:18280/_m/_ssh

Host bob-tcp
  HostName 127.0.0.1
  Port 18322
  User user

Host bob-http
  HostName bob-over-http
  User user
  ProxyCommand h2t http://127.0.0.1:18380/_m/_ssh

