  {
    "name": "list_cgroups",
    "description": "List all cgroups used by processes",
    "inputSchema": {
      "type": "object",
      "properties": {},
      "additionalProperties": false
    }
  },
  {
    "name": "get_cgroup",
    "description": "Get memory info for a specific cgroup path",
    "inputSchema": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "description": "Full cgroup path"
        }
      },
      "required": ["path"],
      "additionalProperties": false
    }
  },
  {
    "name": "move_process",
    "description": "Move a process to a new cgroup subdirectory",
    "inputSchema": {
      "type": "object",
      "properties": {
        "pid": {
          "type": "integer",
          "minimum": 0,
          "description": "Process ID to move"
        },
        "cgroup_name": {
          "type": ["string", "null"],
          "description": "Target cgroup name, or null for the default target"
        }
      },
      "required": ["pid"],
      "additionalProperties": false
    }
  },
  {
    "name": "clear_refs",
    "description": "Clear process memory references via /proc/[pid]/clear_refs",
    "inputSchema": {
      "type": "object",
      "properties": {
        "pid": {
          "type": "integer",
          "minimum": 0,
          "description": "Process ID"
        },
        "value": {
          "type": "string",
          "description": "Value to write: 1-5 or 7 for all"
        }
      },
      "required": ["pid", "value"],
      "additionalProperties": false
    }
  },
  {
    "name": "cgroup_high",
    "description": "Adjust memory.high for a cgroup to a percentage of current usage",
    "inputSchema": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "description": "Full cgroup path"
        },
        "percentage": {
          "type": "number",
          "description": "Percentage of current memory to set as high"
        },
        "interval": {
          "type": "integer",
          "minimum": 0,
          "description": "Seconds before resetting to max, or 0 for no reset"
        }
      },
      "required": ["path", "percentage", "interval"],
      "additionalProperties": false
    }
  },
