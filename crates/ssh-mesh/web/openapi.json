      "ProcessDetailedInfo": {
        "type": "object",
        "description": "Detailed process information including cgroup hierarchy.",
        "required": [
          "process",
          "parent_cgroups"
        ],
        "properties": {
          "cgroup": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/CGroupInfo",
                "description": "Direct cgroup info (if available)"
              }
            ]
          },
          "parent_cgroups": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CGroupInfo"
            },
            "description": "Parent cgroups from the process's cgroup up to root"
          },
          "process": {
            "$ref": "#/components/schemas/ProcessInfo",
            "description": "Core process information"
          }
        }
      },
      "ProcessInfo": {
        "type": "object",
        "required": [
          "pid",
          "ppid",
          "comm"
        ],
        "properties": {
          "cgroup_path": {
            "type": [
              "string",
              "null"
            ]
          },
          "cmdline": {
            "type": [
              "string",
              "null"
            ]
          },
          "comm": {
            "type": "string"
          },
          "mem_info": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ProcMemInfo"
              }
            ]
          },
          "pid": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "ppid": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "uid": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int32",
            "minimum": 0
          }
        }
      },
      "PsiWatchesArgs": {
        "type": "object",
        "description": "Arguments for psi_watches - no parameters needed"
      },
      "SendMessageRequest": {
        "type": "object",
        "required": [
          "message"
        ],
        "properties": {
          "message": {
            "type": "string"
          }
        }
      },
      "TraceLevelRequest": {
        "type": "object",
        "description": "Request body for setting trace level",
        "required": [
          "level"
        ],
        "properties": {
          "level": {
            "type": "string",
            "description": "The new trace level filter directive (e.g., \"info\", \"debug\", \"trace\", \"ssh_mesh=debug,info\")"
          }
        }
      },
      "TraceLevelResponse": {
        "type": "object",
        "description": "Response for getting/setting trace level",
        "required": [
          "level"
        ],
        "properties": {
          "level": {
            "type": "string",
            "description": "The current trace level filter directive"
          },
          "message": {
            "type": [
              "string",
              "null"
            ],
            "description": "Optional message indicating the result of the operation"
          }
        }
      }
    }
