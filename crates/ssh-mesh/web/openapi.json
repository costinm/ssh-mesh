{
  "openapi": "3.1.0",
  "info": {
    "title": "ssh-mesh",
    "description": "",
    "license": {
      "name": ""
    },
    "version": "0.1.0"
  },
  "paths": {
    "/": {
      "get": {
        "tags": [
          "ssh-mesh"
        ],
        "summary": "Fallback reverse proxy handler.",
        "description": "Forwards unmatched requests to `target_http_address` if configured.",
        "operationId": "handle_proxy_request",
        "responses": {
          "200": {
            "description": "Proxied response"
          },
          "404": {
            "description": "No target configured"
          },
          "502": {
            "description": "Proxy error"
          }
        }
      }
    },
    "/_m/_exec/{cmd}": {
      "post": {
        "tags": [
          "ssh-mesh"
        ],
        "summary": "Execute a shell command and stream stdin/stdout over the HTTP/2 body.",
        "description": "Environment variables can be passed via `X-E-<NAME>` request headers.\n\n* `cmd` — Shell command to execute via `sh -c`.",
        "operationId": "handle_exec",
        "parameters": [
          {
            "name": "cmd",
            "in": "path",
            "description": "Command to execute",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Command I/O stream"
          },
          "405": {
            "description": "Method not allowed"
          },
          "500": {
            "description": "Spawn failed"
          }
        }
      }
    },
    "/_m/_ssh": {
      "post": {
        "tags": [
          "ssh-mesh"
        ],
        "summary": "SSH-over-HTTP/2 handler.",
        "description": "Bridges a bidirectional HTTP/2 body stream to a `russh` server session,\nallowing SSH protocol to tunnel over H2C.",
        "operationId": "handle_ssh_request",
        "responses": {
          "200": {
            "description": "SSH session stream"
          },
          "500": {
            "description": "SSH session failed"
          }
        }
      }
    },
    "/_m/_tcp/{host}/{port}": {
      "post": {
        "tags": [
          "ssh-mesh"
        ],
        "summary": "TCP proxy handler.",
        "description": "Connects to `host:port` via TCP and bridges the connection over the HTTP/2 body stream.\n\n* `host` — Target hostname or IP.\n* `port` — Target port number.",
        "operationId": "handle_tcp_proxy",
        "parameters": [
          {
            "name": "host",
            "in": "path",
            "description": "Target host",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "port",
            "in": "path",
            "description": "Target port",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "TCP proxy stream"
          },
          "405": {
            "description": "Method not allowed"
          },
          "502": {
            "description": "Connection failed"
          }
        }
      }
    },
    "/_m/_uds/{path}": {
      "post": {
        "tags": [
          "ssh-mesh"
        ],
        "summary": "Unix domain socket proxy handler.",
        "description": "Connects to a UDS at the given path and bridges it over the HTTP/2 body stream.\n\n* `path` — Absolute path to the Unix domain socket.",
        "operationId": "handle_uds_proxy",
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "description": "UDS socket path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "UDS proxy stream"
          },
          "405": {
            "description": "Method not allowed"
          },
          "502": {
            "description": "Connection failed"
          }
        }
      }
    },
    "/_m/api/ssh/clients": {
      "get": {
        "tags": [
          "ssh-mesh"
        ],
        "operationId": "get_ssh_clients",
        "responses": {
          "200": {
            "description": "List connected SSH clients",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ConnectedClientInfo"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/_m/api/sshc/config/hosts": {
      "get": {
        "tags": [
          "sshc"
        ],
        "summary": "List all hosts from the SSH config file.",
        "operationId": "handle_list_config_hosts",
        "responses": {
          "200": {
            "description": "List of SSH config hosts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/NodeConfig"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/_m/api/sshc/connect": {
      "post": {
        "tags": [
          "sshc"
        ],
        "summary": "Connect to a remote SSH server.",
        "description": "* `req` — Connection parameters (host, port, user, optional server_key).",
        "operationId": "handle_connect",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConnectRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Connection established",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConnectResponse"
                }
              }
            }
          },
          "500": {
            "description": "Connection failed"
          }
        }
      }
    },
    "/_m/api/sshc/connections": {
      "get": {
        "tags": [
          "sshc"
        ],
        "summary": "List all active SSH client connections.",
        "operationId": "handle_list_connections",
        "responses": {
          "200": {
            "description": "Active connections",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ConnectionInfo"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/_m/api/sshc/connections/{id}": {
      "delete": {
        "tags": [
          "sshc"
        ],
        "summary": "Disconnect an SSH client connection by ID.",
        "description": "* `id` — Connection ID to disconnect.",
        "operationId": "handle_disconnect",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Connection ID",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64",
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Disconnected"
          },
          "404": {
            "description": "Connection not found"
          }
        }
      }
    },
    "/_m/api/sshc/connections/{id}/exec": {
      "post": {
        "tags": [
          "sshc"
        ],
        "summary": "Execute a command on a remote SSH connection.",
        "description": "* `id` — Connection ID.\n* `req` — Command to execute.",
        "operationId": "sshc_handle_exec",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Connection ID",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64",
              "minimum": 0
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExecRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Execution result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExecResult"
                }
              }
            }
          },
          "500": {
            "description": "Execution failed"
          }
        }
      }
    },
    "/_m/api/sshc/connections/{id}/forward/local": {
      "post": {
        "tags": [
          "sshc"
        ],
        "summary": "Add a local port forward to a connection.",
        "description": "* `id` — Connection ID.\n* `req` — Local port, remote host, and remote port.",
        "operationId": "handle_add_local_forward",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Connection ID",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64",
              "minimum": 0
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LocalForwardRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Forward added"
          },
          "500": {
            "description": "Failed to add forward"
          }
        }
      }
    },
    "/_m/api/sshc/connections/{id}/forward/remote": {
      "post": {
        "tags": [
          "sshc"
        ],
        "summary": "Add a remote port forward to a connection.",
        "description": "* `id` — Connection ID.\n* `req` — Remote port, local host, and local port.",
        "operationId": "handle_add_remote_forward",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Connection ID",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64",
              "minimum": 0
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RemoteForwardRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Forward added",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RemoteForwardResponse"
                }
              }
            }
          },
          "500": {
            "description": "Failed to add forward"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ConnectRequest": {
        "type": "object",
        "required": [
          "host",
          "port",
          "user"
        ],
        "properties": {
          "host": {
            "type": "string"
          },
          "port": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "server_key": {
            "type": "string",
            "description": "Optional server public key (OpenSSH format). If empty, TOFU."
          },
          "user": {
            "type": "string"
          }
        }
      },
      "ConnectResponse": {
        "type": "object",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          }
        }
      },
      "ConnectedClientInfo": {
        "type": "object",
        "description": "Information about a connected client",
        "required": [
          "id",
          "user",
          "comment",
          "remote_forward_listeners",
          "connected_at"
        ],
        "properties": {
          "comment": {
            "type": "string"
          },
          "connected_at": {
            "type": "string",
            "format": "date-time"
          },
          "id": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "options": {
            "type": [
              "string",
              "null"
            ]
          },
          "remote_forward_listeners": {
            "type": "array",
            "items": {
              "type": "array",
              "items": false,
              "prefixItems": [
                {
                  "type": "string"
                },
                {
                  "type": "integer",
                  "format": "int32",
                  "minimum": 0
                }
              ]
            }
          },
          "user": {
            "type": "string"
          }
        }
      },
      "ConnectionInfo": {
        "type": "object",
        "description": "Metadata about one SSH client connection.",
        "required": [
          "id",
          "host",
          "port",
          "user",
          "forwards"
        ],
        "properties": {
          "forwards": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ForwardInfo"
            }
          },
          "host": {
            "type": "string"
          },
          "id": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "port": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "user": {
            "type": "string"
          }
        }
      },
      "ExecRequest": {
        "type": "object",
        "required": [
          "command"
        ],
        "properties": {
          "command": {
            "type": "string"
          }
        }
      },
      "ExecResult": {
        "type": "object",
        "required": [
          "stdout",
          "stderr",
          "exit_code"
        ],
        "properties": {
          "exit_code": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "stderr": {
            "type": "string"
          },
          "stdout": {
            "type": "string"
          }
        }
      },
      "ForwardInfo": {
        "type": "object",
        "description": "Holds forward metadata for cleanup/tracking.",
        "required": [
          "local_port",
          "remote_host",
          "remote_port",
          "type"
        ],
        "properties": {
          "local_host": {
            "type": "string"
          },
          "local_port": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "remote_host": {
            "type": "string"
          },
          "remote_port": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "type": {
            "type": "string"
          }
        }
      },
      "LocalForwardRequest": {
        "type": "object",
        "required": [
          "local_port",
          "remote_host",
          "remote_port"
        ],
        "properties": {
          "local_port": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "remote_host": {
            "type": "string"
          },
          "remote_port": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          }
        }
      },
      "NodeConfig": {
        "type": "object",
        "description": "A node configuration entry, typically loaded from SSH config or config files.",
        "required": [
          "name",
          "hostname",
          "port",
          "user"
        ],
        "properties": {
          "hostname": {
            "type": "string",
            "description": "The resolved hostname (from `Hostname` or same as name)."
          },
          "name": {
            "type": "string",
            "description": "The alias name from the `Host` directive."
          },
          "port": {
            "type": "integer",
            "format": "int32",
            "description": "The resolved port (from `Port` or default 22).",
            "minimum": 0
          },
          "public_keys": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Public keys associated with this node (OpenSSH format)."
          },
          "user": {
            "type": "string",
            "description": "The resolved user (from `User` or system default)."
          }
        }
      },
      "RemoteForwardRequest": {
        "type": "object",
        "required": [
          "remote_port",
          "local_host",
          "local_port"
        ],
        "properties": {
          "local_host": {
            "type": "string"
          },
          "local_port": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "remote_port": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          }
        }
      },
      "RemoteForwardResponse": {
        "type": "object",
        "required": [
          "actual_port"
        ],
        "properties": {
          "actual_port": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "ssh-mesh",
      "description": "SSH Mesh API"
    },
    {
      "name": "sshc",
      "description": "SSH Client REST API"
    }
  ]
}