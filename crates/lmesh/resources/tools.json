  {
    "name": "wifi.raw.send",
    "title": "Send Raw Wi-Fi",
    "group": "Radio",
    "description": "Send custom raw vendor-action bulk traffic using the stable DMesh marker rather than the ESP-NOW API.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "iface": {
          "type": "string",
          "title": "Interface",
          "default": "wlan1"
        },
        "ctrl_dir": {
          "type": "string",
          "title": "WPA control dir",
          "default": "/run/mesh/wpa-supplicant-nan"
        },
        "channel": {
          "type": "integer",
          "title": "Channel",
          "default": 6,
          "minimum": 1,
          "maximum": 13
        },
        "listen_sec": {
          "type": "integer",
          "title": "Listen seconds",
          "default": 60,
          "minimum": 1
        },
        "destination": {
          "type": "string",
          "title": "Destination MAC",
          "description": "Optional destination MAC. Defaults to broadcast."
        },
        "source": {
          "type": "string",
          "title": "Source MAC",
          "description": "Optional spoofed 802.11 source MAC for raw Wi-Fi TX experiments. Defaults to the interface MAC."
        },
        "tx_variant": {
          "type": "string",
          "title": "TX variant",
          "description": "nl80211 FRAME request shape to try. Monitor variants are explicit debug/data-frame paths and are not used by defaults.",
          "enum": [
            "standard",
            "zero_duration",
            "no_duration",
            "no_offchannel",
            "minimal",
            "dont_wait_ack",
            "dont_wait_no_duration",
            "dont_wait_minimal",
            "onchannel",
            "onchannel_noack",
            "dont_wait_no_cck",
            "no_cck",
            "no_freq",
            "monitor",
            "monitor_active",
            "multicast_data",
            "multicast_data_active",
            "sta_multicast_llc",
            "sta_multicast_llc_active",
            "sta_direct_llc",
            "sta_direct_llc_active",
            "roc",
            "pyroute2"
          ],
          "default": "standard"
        },
        "tx_duration_ms": {
          "type": "integer",
          "title": "TX duration milliseconds",
          "description": "Optional nl80211 frame wait/off-channel duration. Defaults to listen_sec * 1000.",
          "minimum": 0
        },
        "payload": {
          "type": "string",
          "title": "Payload",
          "description": "Command or payload bytes encoded as UTF-8 text."
        }
      },
      "required": [
        "payload"
      ],
      "additionalProperties": false
    }
  },
