  {
    "name": "usb.serial.forward.start",
    "title": "Start USB Serial Forward",
    "group": "USB",
    "description": "Start a generic USB serial UDS forward, optionally also exposed on localhost TCP. Use rfc2217://127.0.0.1:<tcp_port> for flasher tools that need baud/control-line changes; plain socket:// is for simple byte/text clients. Alias: usb.serial.connect.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "port": {
          "type": "string",
          "title": "USB port",
          "description": "Logical USB serial token such as USB0, USB1, or ACM0. lmesh derives the device path and socket path from this token.",
          "default": "USB0"
        },
        "baud": {
          "type": ["integer", "null"],
          "title": "Baud",
          "default": 460800
        },
        "tcp_port": {
          "type": ["integer", "null"],
          "title": "TCP listen port",
          "description": "Optional localhost TCP port to expose the same serial forward, for example 3333 for esptool rfc2217://127.0.0.1:3333.",
          "minimum": 0,
          "maximum": 65535,
          "default": null
        },
        "tcp_mode": {
          "type": "string",
          "title": "TCP mode",
          "description": "How TCP clients are interpreted. Use rfc2217 for flasher tools, framed for newline or 0x00+length binary records, and auto for backwards-compatible RFC2217 auto-detect.",
          "enum": ["auto", "framed", "rfc2217"],
          "default": "auto"
        },
        "handshake": {
          "type": "boolean",
          "title": "Handshake",
          "default": false
        },
        "dtr": {
          "type": "boolean",
          "title": "Pulse DTR",
          "description": "Briefly pulse DTR whenever a UDS/TCP client connects, for boards that use DTR as a UART wake interrupt. Disable this for flasher clients so esptool owns reset timing.",
          "default": false
        },
        "multi": {
          "type": "boolean",
          "title": "Multi-writer",
          "description": "Allow every connected client to send commands. When false, serial output is still broadcast to all clients, but only the first client can write. Text is line-framed, binary records use 0x00 plus a 3-byte big-endian length, and RFC2217 clients switch that client into raw byte forwarding while RFC2217 controls remain interpreted.",
          "default": false
        }
      },
      "additionalProperties": false
    }
  },
